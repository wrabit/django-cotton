{
    "name": "cotton-ui",
    "version": "1.0.0",
    "description": "Cotton UI component library",
    "main": "dist/cotton-ui/cotton-ui.js",
    "author": "wrabit",
    "scripts": {
        "build": "npm-run-all --parallel build:js build:css",
        "build:js": "node ./build.js",
        "build:css": "npx @tailwindcss/cli -i css/cotton-ui.css -o dist/cotton-ui/cotton-ui.css --minify",
        "watch": "npm-run-all --parallel watch:js watch:css",
        "watch:js": "node ./build.js --watch",
        "watch:css": "npx @tailwindcss/cli -i css/cotton-ui.css -o dist/cotton-ui/cotton-ui.css --watch"
    },
    "type": "module",
    "devDependencies": {
        "@tailwindcss/cli": "^4.0.12",
        "autoprefixer": "^10.4.19",
        "brotli-size": "^4.0.0",
        "esbuild": "^0.14.49",
        "postcss": "^8.4.38",
        "postcss-import": "^16.1.0",
        "tailwindcss": "^4.0.12"
    },
    "dependencies": {
        "date-fns": "^3.6.0",
        "npm-run-all": "^4.1.5"
    },
    "license": "ISC"
}
